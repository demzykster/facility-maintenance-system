# CMMS CDSL local/staging environment template.
# Copy to .env.local or .env.staging.local and fill real values locally.
# Never commit real Supabase/Vercel secrets.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

CMMS_KV_DRIVER=supabase
CMMS_KV_AUTH=supabase
CMMS_AUDIT_DRIVER=supabase
CMMS_FILE_DRIVER=supabase
CMMS_SESSION_SECRET=

# Optional operational guards.
CMMS_KV_RATE_LIMIT_MAX=600
CMMS_KV_RATE_LIMIT_WINDOW_MS=60000

# First-admin bootstrap should be enabled only for the short setup window.
CMMS_BOOTSTRAP_ENABLED=false
CMMS_BOOTSTRAP_TOKEN=

# Optional push notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
