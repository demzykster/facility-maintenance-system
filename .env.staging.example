# Empty staging / first pilot env template.
# Copy values into Vercel Environment Variables. Do not put real secrets in git.

VITE_CMMS_APP_MODE=production
VITE_CMMS_STORAGE_PROVIDER=api
VITE_CMMS_STORAGE_API_URL=/api

# Public Supabase values used by the browser login flow.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-side Supabase values used by Vercel API routes.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Temporary v1 KV bridge. This is a launch compromise, not the final normalized CMMS data model.
CMMS_KV_AUTH=supabase
CMMS_KV_DRIVER=supabase
CMMS_KV_SUPABASE_TABLE=cmms_kv_records
CMMS_ALLOW_PRODUCTION_KV_BRIDGE=true

# File/photo storage.
CMMS_FILE_DRIVER=supabase
CMMS_FILE_BUCKET=cmms-files
CMMS_FILE_METADATA_DRIVER=supabase
CMMS_FILE_METADATA_SUPABASE_TABLE=file_metadata

# Audit trail.
CMMS_AUDIT_DRIVER=supabase
CMMS_AUDIT_SUPABASE_TABLE=audit_events

# Anonymous public complaints. The frontend defaults to /api/public/complaints.
CMMS_PUBLIC_COMPLAINTS_ENABLED=true
CMMS_PUBLIC_COMPLAINTS_DRIVER=supabase
CMMS_PUBLIC_COMPLAINT_RATE_LIMIT_MS=60000
VITE_CMMS_PUBLIC_COMPLAINT_API_URL=/api/public/complaints

# First-admin bootstrap only.
# Enable only for the first admin creation, then remove both values and redeploy.
# CMMS_BOOTSTRAP_ENABLED=true
# CMMS_BOOTSTRAP_TOKEN=REPLACE_WITH_ONE_TIME_RANDOM_TOKEN
